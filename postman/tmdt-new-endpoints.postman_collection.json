{
  "info": {
    "name": "TMDT New Endpoints",
    "_postman_id": "f0f7b7a2-9ef7-4a27-a8c8-25f4c68f0e10",
    "description": "Requests for newly added product variant, category search, and invoice alias endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Product - Public",
      "item": [
        {
          "name": "Search Products By Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_base_url}}/products/category/{{categoryId}}",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "category",
                "{{categoryId}}"
              ]
            }
          }
        },
        {
          "name": "Get Product Variants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_base_url}}/products/{{productId}}/variants",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "variants"
              ]
            }
          }
        },
        {
          "name": "Get Variant By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{product_base_url}}/products/variants/{{variantId}}",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "variants",
                "{{variantId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Product - Admin",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"cat-tablet\",\n  \"name\": \"Tablet\",\n  \"slug\": \"tablet\",\n  \"sortOrder\": 2\n}"
            },
            "url": {
              "raw": "{{product_base_url}}/products/categories",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "categories"
              ]
            }
          }
        },
        {
          "name": "Create Variant For Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"color\": \"Titanium Blue\",\n  \"ram\": 8,\n  \"storage\": 256,\n  \"importPrice\": 25000000,\n  \"originalPrice\": 32990000,\n  \"price\": 29990000,\n  \"stockQuantity\": 20,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{product_base_url}}/products/{{productId}}/variants",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "{{productId}}",
                "variants"
              ]
            }
          }
        },
        {
          "name": "Update Variant",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 28990000,\n  \"stockQuantity\": 25,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{product_base_url}}/products/variants/{{variantId}}",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "variants",
                "{{variantId}}"
              ]
            }
          }
        },
        {
          "name": "Soft Delete Variant",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{product_base_url}}/products/variants/{{variantId}}",
              "host": [
                "{{product_base_url}}"
              ],
              "path": [
                "products",
                "variants",
                "{{variantId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Order / Invoice",
      "item": [
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"11111111-1111-1111-1111-111111111111\",\n  \"payment_type\": \"full\",\n  \"payment_method\": \"cod\",\n  \"shipping_name\": \"Nguyen Van A\",\n  \"shipping_phone\": \"0901234567\",\n  \"shipping_province\": \"TP HCM\",\n  \"shipping_district\": \"Quan 1\",\n  \"shipping_ward\": \"Ben Nghe\",\n  \"shipping_street\": \"123 Nguyen Hue\",\n  \"note\": \"Giao gio hanh chinh\",\n  \"items\": [\n    {\n      \"product_variant_id\": \"{{variantId}}\",\n      \"product_name\": \"iPhone 16 Pro\",\n      \"variant_label\": \"Natural Titanium - 256GB\",\n      \"quantity\": 1,\n      \"import_price\": 25000000,\n      \"price\": 29990000,\n      \"item_discount\": 0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{order_base_url}}/orders/invoices",
              "host": [
                "{{order_base_url}}"
              ],
              "path": [
                "orders",
                "invoices"
              ]
            }
          }
        },
        {
          "name": "Get Invoice By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_token}}"
              }
            ],
            "url": {
              "raw": "{{order_base_url}}/orders/invoices/{{orderId}}",
              "host": [
                "{{order_base_url}}"
              ],
              "path": [
                "orders",
                "invoices",
                "{{orderId}}"
              ]
            }
          }
        }
      ]
    }
  ],
