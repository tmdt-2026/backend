{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "5.0",
    "resolvePackageJsonExports": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": ".",
    "paths": {
      "@tmdt/*": ["./apps/tmdt/src/*"],
      "@user-service/*": ["./apps/user-service/src/*"],
      "@product-service/*": ["./apps/product-service/src/*"],
      "@order-service/*": ["./apps/order-service/src/*"],
      "@payment-service/*": ["./apps/payment-service/src/*"],
      "@inventory-service/*": ["./apps/inventory-service/src/*"],
      "@review-service/*": ["./apps/review-service/src/*"],
      "@config-service/*": ["./apps/config-service/src/*"],
      "@promotion-service/*": ["./apps/promotion-service/src/*"],
      "@notification-service/*": ["./apps/notification-service/src/*"]
    },
    "types": ["node", "jest"]
  },
  "include": ["apps/**/*.ts", "apps/**/*.spec.ts", "apps/**/*.e2e-spec.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/prisma.config.ts"
  ]
}